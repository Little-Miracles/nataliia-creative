platform :ios, '17.0'

# Убираем сложные поиски путей, используем стандартный метод Flutter
generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
unless File.exist?(generated_xcode_build_settings_path)
  raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
end

File.foreach(generated_xcode_build_settings_path) do |line|
  matches = line.match(/FLUTTER_ROOT\=(.*)/)
  @flutter_root = matches[1].strip if matches
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), @flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # --- НАЧАЛО БЛОКА МАНИФЕСТОВ ---
    # Список плагинов, на которые ругается Apple
    privacy_targets = ['device_info_plus', 'url_launcher_ios', 'video_player_avfoundation', 'Flutter']
    
    if privacy_targets.include?(target.name)
      puts "Adding Privacy Manifest to #{target.name}"
      # Путь к манифесту (он лежит в Runner)
      privacy_path = File.expand_path('Runner/PrivacyInfo.xcprivacy')
      
      # Добавляем файл в фазу ресурсов каждого конкретного плагина
      if File.exist?(privacy_path)
        group = installer.pods_project.main_group.find_subgroup('Resources', true)
        file_ref = group.find_file_by_path(privacy_path) || group.new_file(privacy_path)
        target.resources_build_phase.add_file_reference(file_ref, true)
      end
    end
    # --- КОНЕЦ БЛОКА МАНИФЕСТОВ ---

    target.build_configurations.each do |config|
      # Устанавливаем 17.0 для соответствия требованиям 2026 года
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      
      # Ваша настройка для обхода ошибки PhaseScriptExecution
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      
      # Убираем лишние исключения архитектур
      config.build_settings.delete 'EXCLUDED_ARCHS[sdk=iphonesimulator*]'
    end
  end
end
