platform :ios, '17.0'

# Умный поиск пути к Flutter: сначала в системе, потом в файлах
def flutter_root
  # В облаке GitHub путь всегда есть здесь:
  flutter_root = ENV['FLUTTER_ROOT'] || ENV['FLUTTER_HOME']
  
  # Если мы на ноутбуке и системыне пути не заданы, ищем в конфиге
  if flutter_root.nil? || flutter_root.empty?
    config_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
    if File.exist?(config_path)
      File.foreach(config_path) do |line|
        matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
        flutter_root = matches[1].strip if matches
      end
    end
  end
  
  flutter_root
end

# Подключаем инструменты Flutter (без риска аварийной остановки)
path_to_helper = File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
require path_to_helper

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Данные вашего профиля разработчика
      config.build_settings['DEVELOPMENT_TEAM'] = 'PCSW3AKAPF'
      config.build_settings['CODE_SIGN_STYLE'] = 'Manual'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      
      # Важно для современных версий Xcode
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end
