platform :ios, '17.0'

# Котик сам найдет, где лежит Flutter, через команду 'which flutter'
def find_flutter_sdk
  flutter_bin = `which flutter`.strip
  if flutter_bin.empty?
    raise "Котик не видит команду flutter. Проверьте установку в YAML."
  end
  # Вычисляем путь к корню SDK из пути к исполняемому файлу
  File.expand_path(File.join(File.dirname(flutter_bin), '..'))
end

@flutter_root = find_flutter_sdk

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), @flutter_root)

flutter_ios_podfile_setup
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # 1. Привязка к вашему сертификату и Team ID (из аудита)[cite: 7, 10]
      config.build_settings['DEVELOPMENT_TEAM'] = 'PCSW3AKAPF'
      config.build_settings['CODE_SIGN_STYLE'] = 'Manual'
      
      # 2. Технические настройки совместимости[cite: 5]
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '17.0'
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      
      # 3. Очистка архитектур для корректной сборки
      config.build_settings.delete 'EXCLUDED_ARCHS[sdk=iphonesimulator*]'
    end
  end
end
