<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>AppStorePrivacyManifestIncluded</key>
    <true/>
    <key>CADisableMinimumFrameDurationOnPhone</key>
    <true/>
    <key>CFBundleDisplayName</key>
    <string>Smart Body Life</string>
    <key>CFBundleExecutable</key>                                                                          
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>com.nataliia.smartbodylife</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Smart Body Life</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>3.0.0</string>
    <key>CFBundleSignature</key>
    <string>????</string>
    <key>CFBundleVersion</key>
    <string>22</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.healthcare-fitness</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <key>NSCameraUsageDescription</key>
    <string>Smart Body Life uses the camera only for scanning food items to calculate calories. Images are processed locally and never uploaded to a server.</string>
    <key>NSHealthShareUsageDescription</key>
    <string>We use your steps and activity data to display your progress. All health data is processed locally on your device and is never uploaded to any external server.</string>
    <key>NSHealthUpdateUsageDescription</key>
    <string>We save your workout results to HealthKit to keep your fitness history consistent. Your data remains private and is not shared with any third-party servers.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>This app needs access to the microphone for voice features within the bio-interface.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>The app needs access to the gallery to select photos for your bio-profile. Data stays on your device.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>The app needs permission to save progress photos to your local gallery.</string>
    <key>UIApplicationSupportsIndirectInputEvents</key>
    <true/>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIMainStoryboardFile</key>
    <string>Main</string>
    <key>UIRequiresFullScreen</key>
    <true/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
</dict>
</plist>
